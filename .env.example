# ==========================================
# MVP Movie Web App - Environment Variables
# ==========================================
# DO NOT ADD REAL SECRETS TO THIS FILE.
# Copy this file to '.env' and replace the placeholder values.

# ------------------------------------------
# Flask Core Settings
# ------------------------------------------
FLASK_APP=src.app
FLASK_ENV=development
FLASK_SECRET_KEY=replace-with-your-super-secure-random-key

# ------------------------------------------
# Database Configuration
# ------------------------------------------
# Using local SQLite for the MVP development environment
DATABASE_URI=sqlite:///moviewebapp.db

# ------------------------------------------
# Security & Encryption
# ------------------------------------------
# MUST be a valid 32-byte url-safe base64 encoded string.
# (Used to encrypt user-specific OMDb API keys in the database)
# Generate via: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode('utf-8'))"
ENCRYPTION_KEY=replace_with_your_generated_32_byte_base64_key=